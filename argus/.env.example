# ─── Argus OSINT Platform ───────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Telegram Bot (REQUIRED for bot functionality) ──────────────────────
# Get a token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Display name for the bot (used in logs and welcome messages).
TELEGRAM_BOT_NAME=ArgusOSINTBot

# ─── AI Analysis (OPTIONAL) ────────────────────────────────────────────
# Google Gemini API key for AI-powered threat intelligence reports.
# Get one at: https://aistudio.google.com/apikey
# Without this key, OSINT scans still work — AI reports will be disabled.
GEMINI_API_KEY=

# ─── Security ──────────────────────────────────────────────────────────
# JWT secret key for API authentication. Auto-generated if not set.
# SESSION_SECRET=

# ─── Database ──────────────────────────────────────────────────────────
# SQLite is the default. You can swap to PostgreSQL by changing this URL.
# ARGUS_DB_URL=sqlite+aiosqlite:///./argus.db

# ─── Server ────────────────────────────────────────────────────────────
# Port for the FastAPI server.
# API_PORT=8000

# ─── Tuning ────────────────────────────────────────────────────────────
# Max concurrent investigations (default: 5)
# MAX_CONCURRENT_INVESTIGATIONS=5

# Per-investigation timeout in seconds (default: 120)
# INVESTIGATION_TIMEOUT_SECONDS=120